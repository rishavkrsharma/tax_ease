# ──────────────────────────────────────────
# SMTP Configuration for Contact Form Emails
# ──────────────────────────────────────────
# Copy this file as .env.local and fill in your credentials
#
# For Gmail: use smtp.gmail.com and generate an App Password
# (Google Account → Security → 2-Step Verification → App Passwords)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where contact form submissions are delivered (keep separate from public hello@anytax.in)
CONTACT_EMAIL=askanytax@gmail.com
